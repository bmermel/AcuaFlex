rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Evidencia de entregas (NO ENTREGADO)
    match /deliveries/{deliveryId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // Default: negar todo lo demás
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

